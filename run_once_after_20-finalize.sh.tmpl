#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────
# Post-apply finalisation — runs once after the dotfiles are written, and
# again only if this file changes. Idempotent.
# ─────────────────────────────────────────────────────────────────────────
set -euo pipefail
info() { printf '\033[1;36m• %s\033[0m\n' "$*"; }
ok()   { printf '\033[1;32m✓ %s\033[0m\n' "$*"; }
warn() { printf '\033[1;33m! %s\033[0m\n' "$*"; }
have() { command -v "$1" >/dev/null 2>&1; }

{{ if ne .chezmoi.os "linux" -}}
exit 0
{{ end -}}

# Seed a private secrets file from the example if one doesn't exist yet,
# so a fresh machine has somewhere to drop keys (never overwrites).
SECRETS="$HOME/.config/zsh/secrets.zsh"
if [ ! -f "$SECRETS" ] && [ -f "$HOME/.config/zsh/secrets.zsh.example" ]; then
  cp "$HOME/.config/zsh/secrets.zsh.example" "$SECRETS"
  chmod 600 "$SECRETS"
  warn "Created $SECRETS from the example — fill in your real keys."
fi

# Make zsh the login shell.
if have zsh && [ "${SHELL:-}" != "$(command -v zsh)" ]; then
  info "Setting zsh as the default shell"
  chsh -s "$(command -v zsh)" || warn "chsh failed — run it manually."
fi

# Pre-install Neovim plugins headlessly so the first real launch is instant.
if have nvim; then
  info "Syncing Neovim plugins (headless)…"
  nvim --headless "+Lazy! sync" +qa 2>/dev/null || warn "nvim plugin sync skipped"
  ok "Neovim ready"
fi

ok "Finalisation complete — log out/in for i3 + shell changes to take effect."
