function mkpytests() {
    # Base directory for the Python modules
    local base_dir="$1"

    # Recursive function to create test directories and files
    function create_tests() {
        # Get the current directory
        local dir="$1"

        # Get all Python files in the current directory
        for file in "${dir}"/*.py
        do
            if [[ -f "$file" ]]; then
                # Remove the base_dir part from file path and .py extension
                local base="${file#$base_dir/}"
                base="${base%.py}"

                # Create a test directory
                local test_dir="tests/${base%/*}"
                mkdir -p "${test_dir}"

                # if it __init__.py file skip
                if [[ "${base##*/}" == "__init__" ]]; then
                    # first touch the __init__.py file
                    touch "${test_dir}/__init__.py"
                    continue
                fi
                # Create a test file in the test directory
                touch "${test_dir}/test_${base##*/}.py"
            fi
        done

        # Get all subdirectories in the current directory
        for sub_dir in "${dir}"/*(/)
        do
            # Ignore any directory named 'tests'
            if [[ "${sub_dir:t}" != "tests" ]]
            then
                create_tests "${sub_dir}"
            fi
        done
    }

    # Call the function with the base directory as the argument
    create_tests "${base_dir}"

    # move the tests directory to the base directory
    mv tests "${base_dir}"
}

function pymktests() {
    # Base directory for the Python modules
    local base_dir="$1"
    local test_dir="${base_dir}/tests"

    # Recursive function to create missing test directories and files
    function create_missing_tests() {
        # Get the current directory
        local dir="$1"

        # Get all Python files in the current directory
        for file in "${dir}"/*.py
        do
            if [[ -f "$file" ]]; then
                # Remove the base_dir part from file path and .py extension
                local base="${file#$base_dir/}"
                base="${base%.py}"

                # Corresponding test directory and file
                local test_dir="${test_dir}/${base%/*}"
                local test_file="${test_dir}/test_${base##*/}.py"

                # if test directory or file doesn't exist, create them
                if [[ ! -d "${test_dir}" || ! -f "${test_file}" ]]; then
                    mkdir -p "${test_dir}"
                    touch "${test_file}"
                fi
            fi
        done

        # Get all subdirectories in the current directory
        for sub_dir in "${dir}"/*(/)
        do
            # Ignore any directory named 'tests'
            if [[ "${sub_dir:t}" != "tests" ]]
            then
                create_missing_tests "${sub_dir}"
            fi
        done
    }

    # Call the function with the base directory as the argument
    create_missing_tests "${base_dir}"
}

