# --- Google Drive upload helper (rclone, remote "gdrive") ---
# Usage: tocloud <file-or-dir> [destination-folder-in-drive]
#   tocloud report.pdf            -> Drive root
#   tocloud report.pdf Backups    -> Drive/Backups (folder auto-created)
tocloud() {
  if [ $# -eq 0 ]; then
    echo "Usage: tocloud <file-or-dir> [drive-folder]"
    return 1
  fi
  rclone copy --progress "$1" "gdrive:${2:-}"
}

