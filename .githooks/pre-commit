#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────
# Secret-scanning pre-commit hook (belt-and-braces over .chezmoiignore).
# Blocks the commit if a staged change looks like an API key / token /
# private key. Activated for every clone via `core.hooksPath .githooks`.
#
# Uses gitleaks if installed (most thorough); otherwise a regex fallback.
# ─────────────────────────────────────────────────────────────────────────
set -euo pipefail
red()  { printf '\033[1;31m%s\033[0m\n' "$*"; }
ylw()  { printf '\033[1;33m%s\033[0m\n' "$*"; }

# Hard block: the real secrets file must never be staged.
if git diff --cached --name-only | grep -qxE '(.*/)?\.config/zsh/secrets\.zsh|(.*/)?secrets\.zsh'; then
  red "✗ BLOCKED: secrets.zsh is staged. It must never be committed."
  exit 1
fi

if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --no-banner || {
    red "✗ BLOCKED: gitleaks found a secret in the staged changes."; exit 1; }
  exit 0
fi

# ── Regex fallback (no gitleaks) ─────────────────────────────────────────
ylw "gitleaks not found — using built-in regex scan (install gitleaks for full coverage)."
PATTERN='sk-[A-Za-z0-9]{20}|sk-ant-|ghp_[A-Za-z0-9]{20}|github_pat_|gho_[A-Za-z0-9]{20}|AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z_-]{20}|xox[baprs]-[A-Za-z0-9-]+|glpat-[A-Za-z0-9_-]{20}|-----BEGIN [A-Z ]*PRIVATE KEY-----|(api[_-]?key|apikey|secret|token|password|passwd|bearer)["'"'"'[:space:]]*[:=]["'"'"'[:space:]]*[A-Za-z0-9_-]{16,}'

hits=0
while IFS= read -r f; do
  [ -z "$f" ] && continue
  # skip files that intentionally contain key PATTERNS/placeholders, not real
  # secrets: this hook itself, docs, and the *.example template.
  case "$f" in
    *.example|*.md|.githooks/*|*/pre-commit|.gitignore) continue;;
  esac
  if git show ":$f" 2>/dev/null | grep -nIEq "$PATTERN"; then
    red "✗ Possible secret in: $f"
    git show ":$f" | grep -nIE "$PATTERN" | sed -E 's/[A-Za-z0-9_-]{12,}/<REDACTED>/g' | head -3
    hits=1
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if [ "$hits" -ne 0 ]; then
  red "✗ BLOCKED: commit aborted. Move secrets to ~/.config/zsh/secrets.zsh (git-ignored)."
  red "  If this is a false positive, commit with --no-verify (use sparingly)."
  exit 1
fi
exit 0
