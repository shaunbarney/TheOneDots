#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────
# Dependency bootstrap — runs once on the first `chezmoi apply`, and again
# only if THIS FILE changes (chezmoi hashes run_once_ scripts).
#
# It is OS-aware and idempotent: every step checks before it acts, so it is
# safe to re-run. It installs everything the configs in this repo expect
# (i3 desktop, terminal stack, Neovim 0.12, CLI tools, fonts, language
# toolchains for the LSPs). Non-Debian systems get clear guidance instead.
#
# chezmoi template vars used: .chezmoi.os / .chezmoi.osRelease.id
# ─────────────────────────────────────────────────────────────────────────
set -euo pipefail

bold()  { printf '\033[1m%s\033[0m\n' "$*"; }
info()  { printf '\033[1;36m• %s\033[0m\n' "$*"; }
ok()    { printf '\033[1;32m✓ %s\033[0m\n' "$*"; }
warn()  { printf '\033[1;33m! %s\033[0m\n' "$*"; }
have()  { command -v "$1" >/dev/null 2>&1; }

{{ if ne .chezmoi.os "linux" -}}
warn "This dotfiles bootstrap targets Linux (i3/X11). Detected: {{ .chezmoi.os }}."
warn "Configs will still be applied, but desktop packages won't be installed."
exit 0
{{ end -}}

OS_ID="{{ .chezmoi.osRelease.id | default "unknown" }}"
OS_LIKE="{{ .chezmoi.osRelease.idLike | default "" }}"

if ! { [ "$OS_ID" = "ubuntu" ] || [ "$OS_ID" = "debian" ] || [[ "$OS_LIKE" == *debian* ]]; }; then
  warn "Non-Debian Linux ($OS_ID). Install the equivalents of the package list"
  warn "in this script with your package manager, then re-run 'chezmoi apply'."
  exit 0
fi

bold "▟█ Bootstrapping dependencies for $OS_ID █▙"

# ── 1. APT packages ──────────────────────────────────────────────────────
APT_PKGS=(
  # window manager / desktop
  i3 i3blocks rofi picom dunst feh flameshot
  brightnessctl playerctl xclip
  # terminal stack
  alacritty tmux zsh
  # CLI tooling
  ripgrep fd-find fzf bat btop git curl wget unzip
  # build + language bases (for Neovim LSPs, treesitter, rust, python venvs)
  build-essential pkg-config libssl-dev
  python3 python3-pip python3-venv
  fontconfig
)

missing=()
for p in "${APT_PKGS[@]}"; do
  dpkg -s "$p" >/dev/null 2>&1 || missing+=("$p")
done
if [ ${#missing[@]} -gt 0 ]; then
  info "apt install: ${missing[*]}"
  sudo apt-get update -qq
  sudo DEBIAN_FRONTEND=noninteractive apt-get install -y "${missing[@]}"
  ok "apt packages installed"
else
  ok "all apt packages already present"
fi

# Debian names fd as fdfind / bat as batcat — add friendly symlinks.
mkdir -p "$HOME/.local/bin"
have fd  || { [ -x /usr/bin/fdfind ] && ln -sf /usr/bin/fdfind "$HOME/.local/bin/fd"; }
have bat || { [ -x /usr/bin/batcat ] && ln -sf /usr/bin/batcat "$HOME/.local/bin/bat"; }

# ── 2. Neovim 0.12 (userspace tarball — apt's is too old) ────────────────
NVIM_MIN=0.10
nvim_ok=false
if have nvim; then
  v=$(nvim --version | head -1 | grep -oE '[0-9]+\.[0-9]+' | head -1 || echo 0)
  awk "BEGIN{exit !($v >= $NVIM_MIN)}" && nvim_ok=true
fi
if ! $nvim_ok; then
  info "Installing Neovim (latest stable) to ~/.local/nvim-linux-x86_64"
  tmp=$(mktemp -d)
  curl -fsSL -o "$tmp/nvim.tar.gz" \
    https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz
  rm -rf "$HOME/.local/nvim-linux-x86_64"
  tar -xzf "$tmp/nvim.tar.gz" -C "$HOME/.local"
  ln -sf "$HOME/.local/nvim-linux-x86_64/bin/nvim" "$HOME/.local/bin/nvim"
  rm -rf "$tmp"
  ok "Neovim installed (~/.local/bin/nvim)"
else
  ok "Neovim present ($(nvim --version | head -1))"
fi

# ── 3. Single-binary tools from upstream (apt versions absent/old) ───────
install_eza() {
  have eza && { ok "eza present"; return; }
  info "Installing eza (modern ls)"
  if have cargo; then cargo install eza >/dev/null 2>&1 && return; fi
  local deb; deb=$(mktemp)
  curl -fsSL -o "$deb" "https://github.com/eza-community/eza/releases/latest/download/eza_x86_64-unknown-linux-gnu.tar.gz" || { warn "eza download failed; skip"; return; }
  tar -xzf "$deb" -C "$HOME/.local/bin" eza 2>/dev/null || warn "eza extract failed"
}
install_lazygit() {
  have lazygit && { ok "lazygit present"; return; }
  info "Installing lazygit"
  local url tmp
  url=$(curl -fsSL https://api.github.com/repos/jesseduffield/lazygit/releases/latest \
        | grep -oE 'https://[^"]*Linux_x86_64.tar.gz' | head -1) || true
  [ -z "${url:-}" ] && { warn "lazygit url not found; skip"; return; }
  tmp=$(mktemp -d); curl -fsSL -o "$tmp/lg.tar.gz" "$url"
  tar -xzf "$tmp/lg.tar.gz" -C "$tmp" lazygit && install "$tmp/lazygit" "$HOME/.local/bin/lazygit"
  rm -rf "$tmp"
}
install_chezmoi() {
  have chezmoi && { ok "chezmoi present"; return; }
  info "Installing chezmoi"
  sh -c "$(curl -fsSL get.chezmoi.io)" -- -b "$HOME/.local/bin"
}
install_gh() {
  have gh && { ok "gh present"; return; }
  info "Installing GitHub CLI"
  (type -p wget >/dev/null) && sudo mkdir -p -m 755 /etc/apt/keyrings
  wget -qO- https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null
  sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null
  sudo apt-get update -qq && sudo apt-get install -y gh
}
install_eza
install_lazygit
install_chezmoi
install_gh

# ── 4. Language toolchains for Neovim LSPs / Mason ───────────────────────
if ! have node; then
  info "Installing Node.js LTS (nvm)"
  export NVM_DIR="$HOME/.nvm"
  [ -d "$NVM_DIR" ] || curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash
  # shellcheck disable=SC1091
  . "$NVM_DIR/nvm.sh" && nvm install --lts
else
  ok "node present ($(node --version))"
fi
have uv     || { info "Installing uv (Python)";  curl -fsSL https://astral.sh/uv/install.sh | sh; }
have rustup || { info "Installing rustup (Rust)"; curl -fsSL https://sh.rustup.rs | sh -s -- -y; }

# ── 5. JetBrains Mono Nerd Font (statusline / terminal glyphs) ───────────
FONT_DIR="$HOME/.local/share/fonts/JetBrainsMonoNF"
if ! fc-list 2>/dev/null | grep -qi 'JetBrainsMono Nerd Font'; then
  info "Installing JetBrains Mono Nerd Font"
  mkdir -p "$FONT_DIR"; tmp=$(mktemp -d)
  curl -fsSL -o "$tmp/jbm.zip" \
    https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip
  unzip -oq "$tmp/jbm.zip" -d "$FONT_DIR" && fc-cache -f "$FONT_DIR" >/dev/null
  rm -rf "$tmp"
  ok "Nerd Font installed"
else
  ok "JetBrains Mono Nerd Font present"
fi

ok "Dependency bootstrap complete"
