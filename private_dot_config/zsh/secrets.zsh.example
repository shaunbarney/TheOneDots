# ~/.config/zsh/secrets.zsh  — PRIVATE, never committed.
#
# This is the EXAMPLE. To use it on a new machine:
#     cp ~/.config/zsh/secrets.zsh.example ~/.config/zsh/secrets.zsh
#     chmod 600 ~/.config/zsh/secrets.zsh
#     # then fill in the real values
#
# ~/.zshrc sources the real file if present:
#     [ -f ~/.config/zsh/secrets.zsh ] && source ~/.config/zsh/secrets.zsh
#
# The real secrets.zsh is git-ignored (.chezmoiignore + the repo pre-commit
# hook) so a key can never reach the public repo. i3blocks widgets read the
# same variables via ~/.config/i3blocks/secret_loader.py.

export OPENAI_API_KEY="REPLACE_ME"
export CHATGPT_API_KEY="REPLACE_ME"
export DEEPSEEK_API_KEY="REPLACE_ME"
export HUGGING_FACE_API_KEY="REPLACE_ME"
export LLAMA_CLOUD_API_KEY="REPLACE_ME"
export ALOHA_API_KEY="REPLACE_ME"
export API_NINJAS_KEY="REPLACE_ME"
export COINGLASS_API_KEY="REPLACE_ME"
export FRED_API_KEY="REPLACE_ME"
export NASDAQ_API_KEY="REPLACE_ME"
export NOTION_API_KEY="REPLACE_ME"
export GITLAB_PAT="REPLACE_ME"
export GITLAB_TOKEN_NAME="REPLACE_ME"
